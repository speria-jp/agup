{
  "name": "@agup/core",
  "version": "0.2.1",
  "description": "Core logic for agup - declarative Claude Managed Agents resource management",
  "author": "Speria Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/speria-jp/agup.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/speria-jp/agup#readme",
  "bugs": {
    "url": "https://github.com/speria-jp/agup/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
