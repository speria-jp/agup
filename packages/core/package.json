{
  "name": "@agup/core",
  "version": "0.1.7",
  "description": "Core logic for agup - declarative Claude Managed Agent resource management",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --target=node --outdir=dist --minify --external @anthropic-ai/sdk --external yaml --external zod",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}